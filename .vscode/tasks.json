{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "Fyp.csproj"
      ],
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Start QA Campus",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "Fyp.csproj",
        "--launch-profile",
        "QACampus"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
  ]
}
